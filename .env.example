# --- Local LLM (bắt buộc cho pipeline thật) ---
# Base URL của server local, kiểu OpenAI-compatible (không hard-code vendor).
# Ví dụ: http://127.0.0.1:11434/v1 (Ollama), http://127.0.0.1:1234/v1 (LM Studio), http://127.0.0.1:8000/v1 (vLLM)
LOCAL_LLM_BASE_URL=
# Id model do **server local** của bạn quy định — đặt bất kỳ tên nào server chấp nhận
LOCAL_LLM_MODEL=
# Tùy chọn: nếu server dùng path khác chat completions (mặc định v1/chat/completions)
LOCAL_LLM_CHAT_PATH=v1/chat/completions
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_SEC=120
# Chỉ dev: 1 = không gọi mạng, dùng stub nội bộ thay vì model local
LOCAL_LLM_MOCK=
